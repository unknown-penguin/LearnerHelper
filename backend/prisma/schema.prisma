generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["knowledge","users"]
}

enum PartOfSpeech {
  noun
  verb
  adjective
  adverb
  pronoun
  preposition
  conjunction
  interjection

  @@schema("knowledge")
}

model Language{
  id String @id @default(cuid())
  name String @unique
  code String @unique
  dictionaries Dictionary[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("knowledge")
}

model Dictionary{
  id String @id @default(cuid())
  name String @unique
  language Language  @relation(fields: [languageId], references: [id])
  languageId String
  words Word[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("knowledge")
}

model Word{
  id String @id @default(cuid())
  word String
  partOfSpeech PartOfSpeech
  definition String
  languageLevel String
  dictionary Dictionary @relation(fields: [dictionaryId], references: [id])
  dictionaryId String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("knowledge")
}

model User{
  id String @id @default(cuid())
  name String
  email String @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  profiles Profile[]

  @@schema("users")
}

model Profile{
  id String @id @default(cuid())
  user User @relation(fields: [userId], references: [id])
  userId String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("users")
}

