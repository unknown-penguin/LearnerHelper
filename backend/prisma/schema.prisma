generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["knowledge"]
}

model Language{
  id Int @id @default(autoincrement())
  name String @unique
  code String @unique
  dictionaries Dictionary[]

  @@schema("knowledge")
}

model Dictionary{
  id Int @id @default(autoincrement())
  name String @unique
  language Language  @relation(fields: [languageId], references: [id])
  languageId Int
  words Word[]

  @@schema("knowledge")
}

model Word{
  id Int @id @default(autoincrement())
  name String
  partOfSpeech String
  definition String
  languageLevel String
  dictionary Dictionary @relation(fields: [dictionaryId], references: [id])
  dictionaryId Int

  @@schema("knowledge")
}


