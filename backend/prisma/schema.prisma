// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["knowledge","users"]
}

enum PartOfSpeech {
  noun
  verb
  adjective
  adverb
  pronoun
  preposition
  conjunction
  interjection

  @@schema("knowledge")
}

model Language{
  id String @id @default(uuid()) @db.Uuid
  name String @unique
  code String @unique
  dictionaries Dictionary[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("knowledge")
}

model Dictionary{
  id String @id @default(uuid()) @db.Uuid
  name String @unique
  language Language  @relation(fields: [languageId], references: [id])
  languageId String @db.Uuid
  words Word[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("knowledge")
}

model Word{
  id String @id @default(uuid()) @db.Uuid
  word String
  partOfSpeech PartOfSpeech
  definition String
  languageLevel String
  dictionary Dictionary @relation(fields: [dictionaryId], references: [id])
  dictionaryId String @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("knowledge")
}

model User{
  id String @id @default(uuid()) @db.Uuid
  name String
  email String @unique
  password String
  profile Profile?
  roles Role[]
  settings Settings?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("users")
}

model Profile{
  id String @id @default(uuid()) @db.Uuid
  user User @relation(fields: [userId], references: [id])
  userId String @unique @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("users")
}

model Role{
  id String @id @default(uuid()) @db.Uuid
  name String @unique
  users User[]
  permissions Permission[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt 

  @@schema("users")
}

model Permission{
  id String @id @default(uuid()) @db.Uuid
  name String @unique
  roles Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("users")
}

model Settings{
  id String @id @default(uuid()) @db.Uuid
  emailNotifications Boolean @default(true)
  pushNotifications Boolean @default(true)
  smsNotifications Boolean @default(false)
  profileVisibility String @default("team")
  searchEngineIndexing Boolean @default(false)
  theme String @default("cyan")
  density String @default("comfortable")
  language String @default("en")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("users")
}

